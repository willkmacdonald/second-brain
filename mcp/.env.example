# MCP server environment variables.
#
# The MCP server is launched by Claude Code via .mcp.json and inherits env
# vars from the parent shell. Export these in ~/.zshrc (or equivalent) so the
# server has them when Claude Code starts it.
#
# LOG_ANALYTICS_WORKSPACE_ID is the canonical name (matches backend config).
# AZURE_LOG_ANALYTICS_WORKSPACE_ID is accepted as a fallback for backward compat.
#
# Find the workspace ID:
#   az containerapp show -n second-brain-api -g shared-services-rg \
#     --query "properties.template.containers[0].env[?name=='LOG_ANALYTICS_WORKSPACE_ID'].value" -o tsv
LOG_ANALYTICS_WORKSPACE_ID=

# Azure auth: uses DefaultAzureCredential -- run `az login` locally, no keys needed.
