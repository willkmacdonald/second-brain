// | order by TimeGenerated desc

// --- Admin Agent failures only ---
// Shows only ERROR+ entries from admin processing.
// Uncomment and run separately.
//
// AppTraces
// | where TimeGenerated > ago(24h)
// | where customDimensions.component in ("admin_agent", "admin_handoff")
// | where SeverityLevel >= 3
// | project
//     TimeGenerated,
//     SeverityLevel,
//     Message = message,
//     CaptureTraceId = tostring(customDimensions.capture_trace_id),
//     Details = customDimensions
// | order by TimeGenerated desc
