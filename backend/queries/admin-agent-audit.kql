// =============================================================================
// What did the Admin Agent do?
// =============================================================================
// Shows Admin Agent processing activity from the last 24 hours:
// items processed, errand items created, failures, and processing duration.
//
// Results are grouped by capture_trace_id so you can see per-capture outcomes.
// =============================================================================

// --- All Admin Agent activity (last 24h) ---
// Shows every log entry from the admin_agent component, ordered by time.
AppTraces
| where TimeGenerated > ago(24h)
| where customDimensions.component == "admin_agent"
    or customDimensions.component == "admin_handoff"
| project
    TimeGenerated,
    SeverityLevel,
    Message = message,
    CaptureTraceId = tostring(customDimensions.capture_trace_id),
    Component = tostring(customDimensions.component),
    Details = customDimensions
| order by TimeGenerated desc

// --- Per-capture processing summary ---
